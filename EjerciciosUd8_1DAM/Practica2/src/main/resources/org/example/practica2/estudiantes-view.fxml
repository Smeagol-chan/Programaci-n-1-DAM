<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="600.0" spacing="20.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.practica2.EstudiantesController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
   <TableView fx:id="tablaTableView" prefHeight="400.0" prefWidth="200.0">
     <columns>
       <TableColumn fx:id="niaTableColumn" prefWidth="75.0" text="NIA" />
       <TableColumn fx:id="nombreTableColumn" prefWidth="75.0" text="Nombre" />
         <TableColumn fx:id="fechaNacimientoTableColumn" prefWidth="75.0" text="Fecha de nacimiento" />
     </columns>
      <columnResizePolicy>
         <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
      </columnResizePolicy>
   </TableView>
   <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
      <children>
         <Button fx:id="editarButton" mnemonicParsing="false" onAction="#onEditarButtonClick" text="Editar">
            <HBox.margin>
               <Insets right="5.0" />
            </HBox.margin>
         </Button>
         <Button fx:id="eliminarButton" mnemonicParsing="false" onAction="#onEliminarButtonClick" text="Eliminar">
            <HBox.margin>
               <Insets left="5.0" />
            </HBox.margin>
         </Button>
      </children>
   </HBox>
   <Label fx:id="notificacionLabel" textAlignment="CENTER" />
   <TextField fx:id="niaTextField" promptText="NIA" />
   <TextField fx:id="nombreTextField" promptText="Nombre" />
   <DatePicker fx:id="fechaNacimientoDatePicker" promptText="Fecha de nacimiento" />
   <HBox alignment="CENTER" prefHeight="100.0" prefWidth="200.0">
      <children>
         <Button fx:id="insertarButton" mnemonicParsing="false" onAction="#onInsertarButtonClick" text="Insertar">
            <HBox.margin>
               <Insets right="5.0" />
            </HBox.margin>
         </Button>
          <Button fx:id="guardarButton" disable="true" onAction="#onGuardarButtonClick" text="Guardar">
            <HBox.margin>
               <Insets left="5.0" />
            </HBox.margin>
         </Button>
      </children>
   </HBox>
</VBox>
